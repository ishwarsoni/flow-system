# ══════════════════════════════════════════════════════════════════════════════
#  FLOW Backend — Environment Variables
#  Copy this file to .env and fill in real values. NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════════════════

# Database
DATABASE_URL=sqlite:///./flow.db

# JWT — Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_GENERATE_A_REAL_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
DEBUG=False
APP_NAME=FLOW

# Redis (token blacklist — leave empty for in-memory fallback in dev)
REDIS_URL=redis://127.0.0.1:6379/0

# Security (rate limits)
LOGIN_RATE_LIMIT=5/minute
REGISTER_RATE_LIMIT=3/minute
GLOBAL_RATE_LIMIT=120/minute
MAX_REQUEST_BODY_BYTES=1048576

# Account Lockout
LOCKOUT_THRESHOLD=10
LOCKOUT_WINDOW_MINUTES=15
LOCKOUT_DURATION_MINUTES=15

# Secret rotation reminder
SECRET_ROTATION_DAYS=90

# CORS — add your production domain here
ALLOWED_ORIGINS=["https://yourdomain.com"]

# AI (optional)
OPENAI_API_KEY=
GROQ_API_KEY=

# Sentry (optional monitoring)
SENTRY_DSN=
